# ============================================
# Collaborative Study Vault — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# ============================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000
# Set to "production" in deployment. Controls cookie security, logging level, etc.
NODE_ENV=development
# The URL of your frontend SPA. Used for CORS origin, CSRF cookie domain, and
# Content-Security-Policy connect-src directives.
FRONTEND_URL=http://localhost:5173

# ── MongoDB Atlas (recommended) ──────────────────────────────────────────────
# 1. Create free cluster at https://cloud.mongodb.com
# 2. Database Access → create user with password
# 3. Network Access → Add IP Address → "Allow Access from Anywhere" (0.0.0.0/0) for dev
# 4. Connect → Drivers → copy connection string, then:
#    - Replace <password> with your password (URL-encode special chars: @ → %40, # → %23)
#    - Add database name before ? :  ...mongodb.net/collaborative-study-vault?retryWrites=true...
#
# Example Atlas URI:
# MONGO_URI=mongodb+srv://myuser:MyP%40ssw0rd@cluster0.xxxxx.mongodb.net/collaborative-study-vault?retryWrites=true&w=majority

# Local MongoDB (only if MongoDB is installed and running on your PC):
# MONGO_URI=mongodb://127.0.0.1:27017/collaborative-study-vault

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
# If Node fails with "querySrv ECONNREFUSED" (common on Windows), uncomment:
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# ── Authentication & Security ────────────────────────────────────────────────
# CRITICAL: Change this to a strong, random 256-bit+ string in production.
# Used to sign both access (15 min) and refresh (7 day) JWTs.
# Generate one via:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING

# ── CSRF Protection ─────────────────────────────────────────────────────────
# The double-submit cookie CSRF system is enabled by default. No extra config
# needed. The XSRF-TOKEN cookie is set on auth endpoints and validated on
# state-changing requests (POST/PUT/PATCH/DELETE). The frontend must read the
# cookie and send it back as the X-XSRF-TOKEN header (Axios does this
# automatically with withCredentials: true + xsrfCookieName configured).

# ── Cloudinary (file & past-paper uploads) ───────────────────────────────────
# Sign up at https://cloudinary.com (free tier available)
# Dashboard → Account Details → copy cloud name, API key, and API secret.
# Required if you want to upload files or past papers.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Powers: AI chat tutor, auto-summarization, quiz generation, flashcards.
# Obtain a free key from: https://aistudio.google.com/
# Optional — AI uses local engine when empty, rate-limited (429), or FORCE_LOCAL_AI=true
GEMINI_API_KEY=
# Optional model override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
# Skip Gemini entirely (no 429 waits) — recommended for demos without API quota
# FORCE_LOCAL_AI=true
# After a 429, skip Gemini calls for this many minutes (default 15)
# GEMINI_COOLDOWN_MINUTES=15

# ── Rate Limiting & Brute Force ──────────────────────────────────────────────
# The server auto-locks accounts for 15 min after 5 failed login attempts.
# Socket.IO events are rate-limited per-connection (see socketRateLimiter.js).
# No extra config needed — these are hardcoded sensible defaults.
